   def _calculate_hurst_exponent(self, series):
        """Calculate Hurst exponent using R/S analysis"""
        try:
            if len(series) < 10:
                return np.nan
            
            # Convert to log returns
            log_returns = np.log(series / series.shift(1)).dropna()
            
            if len(log_returns) < 5:
                return np.nan
            
            # Calculate cumulative deviate
            mean_return = log_returns.mean()
            cumulative_deviate = np.cumsum(log_returns - mean_return)
            
            # Calculate range
            R = np.max(cumulative_deviate) - np.min(cumulative_deviate)
            
            # Calculate standard deviation
            S = np.std(log_returns)
            
            if S == 0:
                return np.nan
            
            # R/S ratio
            rs_ratio = R / S
            
            # Hurst exponent approximation
            if rs_ratio > 0:
                return np.log(rs_ratio) / np.log(len(log_returns))
            else:
                return np.nan
        except:
            return np.nan
    
    def _calculate_entropy(self, series):
        """Calculate Shannon entropy of price movements"""
        try:
            if len(series) < 5:
                return np.nan
            
            # Calculate returns and bin them
            returns = series.pct_change().dropna()
            
            if len(returns) < 3:
                return np.nan
            
            # Create bins for returns
            bins = np.linspace(returns.min(), returns.max(), 10)
            hist, _ = np.histogram(returns, bins=bins)
            
            # Calculate probabilities
            probs = hist / hist.sum()
            
            # Remove zero probabilities
            probs = probs[probs > 0]
            
            # Calculate entropy
            entropy = -np.sum(probs * np.log2(probs))
            return entropy
        except:
            return np.nan
    
    def _detect_market_regime(self, prices):
        """Detect market regime using moving averages and volatility"""
        try:
            # Calculate multiple moving averages
            sma_5 = prices.rolling(window=5).mean()
            sma_20 = prices.rolling(window=20).mean()
            sma_50 = prices.rolling(window=50).mean()
            
            # Calculate volatility
            volatility = prices.rolling(window=20).std()
            
            # Regime indicator based on moving average relationships
            regime = pd.Series(index=prices.index, dtype=float)
            
            # Uptrend: short MA > medium MA > long MA
            uptrend = (sma_5 > sma_20) & (sma_20 > sma_50)
            
            # Downtrend: short MA < medium MA < long MA
            downtrend = (sma_5 < sma_20) & (sma_20 < sma_50)
            
            # Sideways: mixed signals
            sideways = ~uptrend & ~downtrend
            
            regime[uptrend] = 1.0  # Bullish
            regime[downtrend] = -1.0  # Bearish
            regime[sideways] = 0.0  # Neutral
            
            return regime
        except:
            return pd.Series(index=prices.index, dtype=float)
    
    def _detect_market_phase(self, df):
        """Detect market phase: accumulation, markup, distribution, markdown"""
        try:
            price = df['price']
            volume = df['volume']
            
            # Calculate price and volume momentum
            price_momentum = price.rolling(window=20).mean().pct_change()
            volume_momentum = volume.rolling(window=20).mean().pct_change()
            
            # Price trend strength
            price_trend = (price.rolling(window=5).mean() - price.rolling(window=20).mean()) / price.rolling(window=20).mean()
            
            # Volume trend strength
            volume_trend = (volume.rolling(window=5).mean() - volume.rolling(window=20).mean()) / volume.rolling(window=20).mean()
            
            # Market phase classification
            phase = pd.Series(index=df.index, dtype=str)
            
            # Accumulation: flat price, increasing volume
            accumulation = (abs(price_trend) < 0.01) & (volume_trend > 0.1)
            
            # Markup: rising price, high volume
            markup = (price_trend > 0.02) & (volume_trend > 0)
            
            # Distribution: flat price, high volume
            distribution = (abs(price_trend) < 0.01) & (volume_trend > 0.1)
            
            # Markdown: falling price
            markdown = (price_trend < -0.02)
            
            phase[accumulation] = 'accumulation'
            phase[markup] = 'markup'
            phase[distribution] = 'distribution'
            phase[markdown] = 'markdown'
            phase[~(accumulation | markup | distribution | markdown)] = 'neutral'
            
            return phase
        except:
            return pd.Series(index=df.index, dtype=str)
    
    def _calculate_mean_reversion_strength(self, prices):
        """Calculate mean reversion strength using autocorrelation"""
        try:
            returns = prices.pct_change().dropna()
            
            # Calculate first-order autocorrelation
            autocorr = returns.rolling(window=20).apply(lambda x: x.autocorr(lag=1))
            
            # Mean reversion strength (negative autocorrelation indicates mean reversion)
            mean_reversion = -autocorr
            
            return mean_reversion
        except:
            return pd.Series(index=prices.index, dtype=float)
    
    def _calculate_trend_persistence(self, prices):
        """Calculate trend persistence using consecutive price movements"""
        try:
            returns = prices.pct_change()
            
            # Calculate consecutive up/down movements
            up_moves = (returns > 0).astype(int)
            down_moves = (returns < 0).astype(int)
            
            # Count consecutive movements
            trend_persistence = pd.Series(index=prices.index, dtype=float)
            
            for i in range(20, len(prices)):
                recent_moves = returns.iloc[i-20:i]
                up_streaks = []
                down_streaks = []
                
                current_streak = 0
                for move in recent_moves:
                    if move > 0:
                        current_streak += 1
                    else:
                        if current_streak > 0:
                            up_streaks.append(current_streak)
                        current_streak = 0
                
                current_streak = 0
                for move in recent_moves:
                    if move < 0:
                        current_streak += 1
                    else:
                        if current_streak > 0:
                            down_streaks.append(current_streak)
                        current_streak = 0
                
                # Average streak length
                all_streaks = up_streaks + down_streaks
                avg_streak = np.mean(all_streaks) if all_streaks else 1
                trend_persistence.iloc[i] = avg_streak
            
            return trend_persistence
        except:
            return pd.Series(index=prices.index, dtype=float)
    
    def _detect_jumps(self, prices):
        """Detect price jumps using statistical methods"""
        try:
            returns = prices.pct_change().dropna()
            
            # Calculate rolling mean and standard deviation
            rolling_mean = returns.rolling(window=20).mean()
            rolling_std = returns.rolling(window=20).std()
            
            # Detect jumps (returns beyond 3 standard deviations)
            jumps = abs(returns - rolling_mean) > (3 * rolling_std)
            
            return jumps
        except:
            return pd.Series(index=prices.index, dtype=bool)
    
    def _calculate_regime_change_probability(self, prices):
        """Calculate probability of regime change"""
        try:
            # Calculate various indicators
            returns = prices.pct_change()
            volatility = returns.rolling(window=20).std()
            
            # Volatility change
            vol_change = volatility.pct_change()
            
            # Price momentum change
            momentum = prices.rolling(window=10).mean().pct_change()
            momentum_change = momentum.pct_change()
            
            # Combine indicators (simplified approach)
            regime_change_signal = abs(vol_change) + abs(momentum_change)
            
            # Convert to probability (0-1 scale)
            prob = regime_change_signal.rolling(window=10).rank(pct=True)
            
            return prob
        except:
            return pd.Series(index=prices.index, dtype=float)
    
