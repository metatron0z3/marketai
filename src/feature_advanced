    def add_support_resistance_level(self, symbol: str, level_type: str, price_level: float, strength: float = 1.0):
        """
        Manually add support or resistance level
        
        Args:
            symbol: Trading symbol
            level_type: 'support' or 'resistance'
            price_level: Price level
            strength: Strength of the level (1.0 = normal, higher = stronger)
        """
        if symbol not in self.support_resistance_levels:
            self.support_resistance_levels[symbol] = {'support': [], 'resistance': []}
        
        level_data = {
            'price': price_level,
            'strength': strength,
            'created_at': datetime.now(),
            'test_count': 0,
            'last_tested': None
        }
        
        self.support_resistance_levels[symbol][level_type].append(level_data)
        
        # Also save to database
        self._save_sr_level_to_db(symbol, level_type, level_data)
        
        logger.info(f"Added {level_type} level {price_level} for {symbol} with strength {strength}")
    
    def _save_sr_level_to_db(self, symbol: str, level_type: str, level_data: dict):
        """Save support/resistance level to database"""
        cursor = self.connection.cursor()
        try:
            insert_sql = """
                INSERT INTO support_resistance_levels 
                (symbol, level_type, price_level, strength, created_at, test_count, is_active)
                VALUES (%s, %s, %s, %s, %s, %s, %s)
            """
            cursor.execute(insert_sql, (
                symbol, level_type, level_data['price'], level_data['strength'],
                level_data['created_at'], level_data['test_count'], True
            ))
            self.connection.commit()
        except Exception as e:
            logger.error(f"Error saving S/R level to database: {e}")
        finally:
            cursor.close()
    
    def load_support_resistance_levels(self, symbol: str):
        """Load existing support/resistance levels from database"""
        cursor = self.connection.cursor()
        try:
            cursor.execute("""
                SELECT level_type, price_level, strength, created_at, test_count, last_tested
                FROM support_resistance_levels
                WHERE symbol = %s AND is_active = true
                ORDER BY created_at
            """, (symbol,))
            
            results = cursor.fetchall()
            
            if symbol not in self.support_resistance_levels:
                self.support_resistance_levels[symbol] = {'support': [], 'resistance': []}
            
            for row in results:
                level_type, price_level, strength, created_at, test_count, last_tested = row
                level_data = {
                    'price': price_level,
                    'strength': strength,
                    'created_at': created_at,
                    'test_count': test_count,
                    'last_tested': last_tested
                }
                self.support_resistance_levels[symbol][level_type].append(level_data)
            
            logger.info(f"Loaded {len(results)} S/R levels for {symbol}")
            
        except Exception as e:
            logger.error(f"Error loading S/R levels: {e}")
        finally:
            cursor.close()
    
    def _find_nearest_sr_level(self, symbol: str, current_price: float) -> Tuple[float, str, float]:
        """Find nearest support/resistance level and return distance, type, and strength"""
        if symbol not in self.support_resistance_levels:
            return 0.0, 'none', 0.0
        
        all_levels = []
        for level_type in ['support', 'resistance']:
            for level in self.support_resistance_levels[symbol][level_type]:
                all_levels.append((level['price'], level_type, level['strength']))
        
        if not all_levels:
            return 0.0, 'none', 0.0
        
        # Find closest level
        distances = [abs(current_price - level[0]) for level in all_levels]
        nearest_idx = np.argmin(distances)
        nearest_level = all_levels[nearest_idx]
        
        distance = (current_price - nearest_level[0]) / current_price  # Normalized distance
        return distance, nearest_level[1], nearest_level[2]
    
    def _calculate_sr_features(self, symbol: str, current_price: float) -> dict:
        """Calculate support/resistance related features"""
        if symbol not in self.support_resistance_levels:
            return {
                'distance_to_support': 0.0,
                'distance_to_resistance': 0.0,
                'support_strength': 0.0,
                'resistance_strength': 0.0,
                'nearest_level_type': 'none'
            }
        
        # Find nearest support below current price
        supports = [level for level in self.support_resistance_levels[symbol]['support'] 
                   if level['price'] < current_price]
        nearest_support = max(supports, key=lambda x: x['price']) if supports else None
        
        # Find nearest resistance above current price
        resistances = [level for level in self.support_resistance_levels[symbol]['resistance'] 
                      if level['price'] > current_price]
        nearest_resistance = min(resistances, key=lambda x: x['price']) if resistances else None
        
        # Calculate distances and strengths
        distance_to_support = ((current_price - nearest_support['price']) / current_price) if nearest_support else 1.0
        distance_to_resistance = ((nearest_resistance['price'] - current_price) / current_price) if nearest_resistance else 1.0
        
        support_strength = nearest_support['strength'] if nearest_support else 0.0
        resistance_strength = nearest_resistance['strength'] if nearest_resistance else 0.0
        
        # Determine nearest level type
        if distance_to_support < distance_to_resistance:
            nearest_level_type = 'support'
        elif distance_to_resistance < distance_to_support:
            nearest_level_type = 'resistance'
        else:
            nearest_level_type = 'none'
        
    def load_trade_data(self, symbol: str, start_time: datetime, end_time: datetime) -> pd.DataFrame:
        """Load trade data from QuestDB for a specific symbol and time range"""
        query = """
            SELECT ts, symbol, price, size as volume
            FROM trades 
            WHERE symbol = %s 
            AND ts >= %s 
            AND ts <= %s
            ORDER BY ts
        """
        
        try:
            df = pd.read_sql_query(
                query, 
                self.connection, 
                params=[symbol, start_time, end_time]
            )
            df['ts'] = pd.to_datetime(df['ts'])
            df.set_index('ts', inplace=True)
            logger.info(f"Loaded {len(df)} trades for {symbol}")
            return df
        except Exception as e:
            logger.error(f"Error loading trade data: {e}")
            return pd.DataFrame()
    
    def calculate_price_features(self, df: pd.DataFrame) -> pd.DataFrame:
        """Calculate price-based features"""
        features = pd.DataFrame(index=df.index)
        features['symbol'] = df['symbol']
        features['price'] = df['price']
        
