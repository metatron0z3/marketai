# Copy to .env and fill in before running
# Never commit .env to git

SCHWAB_API_KEY=your_schwab_app_key_here
SCHWAB_APP_SECRET=your_schwab_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Points to MarketAI's shared Prefect server
PREFECT_API_URL=http://localhost:4200/api

# Override if running TOS stack on a different host
TOS_QUESTDB_HOST=localhost
TOS_QUESTDB_PORT=9100
TOS_POSTGRES_HOST=localhost
TOS_POSTGRES_PORT=5433
